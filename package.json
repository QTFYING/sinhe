{
  "name": "shou-sevices",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm -F @shou/types build && turbo run dev --filter=@shou/types --filter=api",
    "dev:api": "pnpm -F @shou/types build && pnpm -F api start:dev",
    "dev:types": "pnpm -F @shou/types dev",
    "dev:worker": "pnpm -F @shou/types build && pnpm -F api start:import-worker",
    "dev:swagger": "pnpm run dev:api",
    "check:backend": "pnpm -F @shou/types build && pnpm -F api build && pnpm -F api test:smoke && pnpm -F api test:backend-regression",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:init": "node scripts/db-init.js",
    "db:seed": "node scripts/db-seed.js"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0"
  }
}
