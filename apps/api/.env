# PostgreSQL 连接配置 (本地直连环境)
# 格式: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/distributor_pay?schema=public"

# Redis 连接配置 (本地无密码)
REDIS_URL="redis://localhost:6379"

# 其它系统环境变量
JWT_SECRET="super-secret-development-key-for-distributor-pay"
