// schema.prisma (PostgreSQL)
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- GLOBAL ENUMS ----------------
enum UserRoleEnum {
  OS_SUPER_ADMIN
  OS_OPERATOR
  TENANT_OWNER
  TENANT_OPERATOR
  TENANT_FINANCE
  TENANT_VIEWER
}

enum PayStatusEnum {
  UNPAID
  PAYING
  PARTIAL_PAID
  PAID
  REFUNDED
}

enum DeliveryStatusEnum {
  PENDING
  IN_TRANSIT
  DELIVERED
}

enum PaymentMethodEnum {
  ONLINE_PAYMENT
  MANUAL_MARKUP
}

enum PaymentRecordStatusEnum {
  SUCCESS
  FAILED
  REFUNDED
}

enum LifecycleEventEnum {
  ORDER_CREATED
  ORDER_PRINTED
  PAYMENT_INITIATED
  PAYMENT_SUCCESS_WEBHOOK
  PAYMENT_SUCCESS_POLLING
  PAYMENT_MANUAL_MARKUP
  PRICE_ADJUSTED
  ORDER_REFUNDED
  QR_CODE_EXPIRED
  DELIVERY_STATUS_UPDATED
}

enum NotificationTypeEnum {
  CREDIT_OVERDUE_REMINDER
}

// ---------------- MODELS ----------------

model Agent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(100)
  contactPhone   String   @unique @db.VarChar(20)
  commissionRate Decimal  @default(0.00) @db.Decimal(5, 4)

  tenants            Tenant[]
  commissionLedgers  AgentCommissionLedger[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@map("sys_agent")
}

model Tenant {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId      String?  @db.Uuid
  name         String   @db.VarChar(100)
  contactPhone String   @db.VarChar(20)
  status       Int      @default(1)
  paymentConfig Json?   @default("{}")
  expireAt     DateTime?

  maxCreditDays      Int  @default(30)
  creditReminderDays Int  @default(3)

  agent           Agent?           @relation(fields: [agentId], references: [id])
  users           User[]
  orders          Order[]
  importTemplates ImportTemplate[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@map("sys_tenant")
}

model User {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String?      @db.Uuid
  username     String       @db.VarChar(50)
  passwordHash String       @db.VarChar(255)
  realName     String       @db.VarChar(50)
  role         UserRoleEnum
  status       Int          @default(1)

  tenant        Tenant?              @relation(fields: [tenantId], references: [id])
  lifecycleLogs OrderLifecycleLog[]
  manualPayments PaymentRecord[]
  notifications  Notification[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([tenantId, username])
  @@map("sys_user")
}

model ImportTemplate {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String  @db.Uuid
  templateName String  @db.VarChar(100)
  mappingRules Json
  customFieldDefs Json?  @default("[]")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  orders  Order[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("biz_import_template")
}

model Order {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String  @db.Uuid
  erpOrderNo      String  @db.VarChar(100)
  customerName    String  @db.VarChar(100)
  customerPhone   String? @db.VarChar(20)
  deliveryAddress String? @db.VarChar(255)
  deliveryPersonName String? @db.VarChar(50)
  templateId      String?  @db.Uuid
  customFields    Json?    @default("{}")

  totalAmount    Decimal  @db.Decimal(10, 2)
  paidAmount     Decimal  @default(0.00) @db.Decimal(10, 2)
  discountAmount Decimal  @default(0.00) @db.Decimal(10, 2)

  payStatus      PayStatusEnum      @default(UNPAID)
  deliveryStatus DeliveryStatusEnum @default(PENDING)

  qrCodeToken    String    @unique @db.VarChar(64)
  qrExpireAt     DateTime
  creditExpireAt DateTime

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  template  ImportTemplate? @relation(fields: [templateId], references: [id])
  items     OrderItem[]
  payments  PaymentRecord[]
  logs      OrderLifecycleLog[]
  creditReminders  OrderCreditReminder[]
  notifications    Notification[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  @@unique([tenantId, erpOrderNo])
  @@index([tenantId, payStatus])
  @@map("biz_order")
}

model OrderItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String  @db.Uuid
  productName String  @db.VarChar(200)
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(10, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("biz_order_item")
}

model PaymentRecord {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @db.Uuid
  tenantId  String  @db.Uuid

  actualAmount  Decimal             @db.Decimal(10, 2)
  paymentMethod PaymentMethodEnum

  channel        String?  @db.VarChar(50)
  channelTradeNo String?  @unique @db.VarChar(100)
  feeAmount      Decimal  @default(0.00) @db.Decimal(10, 2)
  rawCallbackData Json?

  operatorId  String?  @db.Uuid
  markReason  String?  @db.VarChar(500)

  status    PaymentRecordStatusEnum  @default(SUCCESS)
  paidTime  DateTime

  order     Order  @relation(fields: [orderId], references: [id])
  operator  User?  @relation(fields: [operatorId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([orderId])
  @@map("biz_payment_record")
}

model OrderLifecycleLog {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String              @db.Uuid
  tenantId  String              @db.Uuid
  event     LifecycleEventEnum
  operatorId  String?  @db.Uuid
  snapshot    Json?
  remark      String?  @db.VarChar(500)

  order     Order  @relation(fields: [orderId], references: [id])
  operator  User?  @relation(fields: [operatorId], references: [id])

  createdAt  DateTime  @default(now())

  @@index([orderId])
  @@index([tenantId, event])
  @@map("biz_order_lifecycle_log")
}

model Notification {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String               @db.Uuid
  recipientId String               @db.Uuid
  type        NotificationTypeEnum
  title       String               @db.VarChar(200)
  content     String               @db.VarChar(1000)
  isRead      Boolean              @default(false)
  readAt      DateTime?
  relatedOrderId  String?  @db.Uuid

  order      Order?  @relation(fields: [relatedOrderId], references: [id])
  recipient  User    @relation(fields: [recipientId], references: [id])

  createdAt  DateTime  @default(now())

  @@index([recipientId, isRead])
  @@index([tenantId, createdAt])
  @@map("sys_notification")
}

model OrderCreditReminder {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId  String  @db.Uuid
  tenantId String  @db.Uuid
  reminderStage  String    @db.VarChar(50)
  sentAt         DateTime  @default(now())

  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([orderId, reminderStage])
  @@index([tenantId])
  @@map("biz_order_credit_reminder")
}

model AgentCommissionLedger {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId          String   @db.Uuid
  tenantId         String   @db.Uuid
  settlementDate   DateTime @db.Date
  totalOrderAmount  Decimal  @db.Decimal(12, 2)
  commissionRate    Decimal  @db.Decimal(5, 4)
  commissionAmount  Decimal  @db.Decimal(10, 2)
  status            Int      @default(0)

  agent  Agent  @relation(fields: [agentId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([agentId, tenantId, settlementDate])
  @@index([agentId, status])
  @@map("biz_agent_commission_ledger")
}
