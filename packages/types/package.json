{
  "name": "@shou/types",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/contracts/index.js",
  "exports": {
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "default": "./dist/common/index.js"
    },
    "./enums": {
      "types": "./dist/enums/index.d.ts",
      "default": "./dist/enums/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "contracts": ["./dist/contracts/index.d.ts"],
      "common": ["./dist/common/index.d.ts"],
      "enums": ["./dist/enums/index.d.ts"]
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
